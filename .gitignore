# ──────────────────────────────────────────────
# Denali Health BD Automation — .gitignore
# ──────────────────────────────────────────────

# Secrets — NEVER commit
.env
.env.local
.env.*.local
*.key
*.pem

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# SQLite database (local data, do not commit)
*.db
*.sqlite
*.sqlite3
*.db-journal
denali.db

# Uploaded CSVs and runtime files (keep folder, ignore contents)
uploads/*
!uploads/.gitkeep

# Logs
*.log
logs/

# IDE / editors
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pyre/

# Gmail mailbox config — contains app passwords, never commit
mailboxes.json

# Google service account key — contains private key, never commit
google_credentials.json
