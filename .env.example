# ─────────────────────────────────────────────────
# Denali Health BD Automation — Environment config
#
# 1. Copy this file:    cp .env.example .env
# 2. Fill in your keys (the .env is gitignored — safe)
# 3. NEVER commit .env to git
# ─────────────────────────────────────────────────


# ── App ─────────────────────────────────────────
APP_ENV=development                    # development | production
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR

# Single-password HTTPBasic auth for ALL routes except /health.
# Leave EMPTY in dev to disable auth. REQUIRED for any public-facing deploy.
APP_PASSWORD=

# Comma-separated list of allowed CORS origins for production.
# Leave empty in dev (wildcard). In prod set to your domain, e.g.:
# ALLOWED_ORIGINS=https://denali-bd.onrender.com,https://bd.denalihealth.com
ALLOWED_ORIGINS=


# ── Database ────────────────────────────────────
# SQLite file path. In dev: ./denali.db (project root).
# On Render: /data/denali.db (persistent disk mount).
DATABASE_PATH=./denali.db


# ── Anthropic (AI email generation) ─────────────
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Model — Sonnet is the right balance for email drafting.
# Options: claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024


# ── Apollo.io (contact enrichment) ──────────────
# Get key: https://app.apollo.io/  →  Settings  →  Integrations  →  API
APOLLO_API_KEY=REPLACE_ME
# Verify base URL in Apollo's current docs before going live
APOLLO_BASE_URL=https://api.apollo.io/api/v1


# ── Instantly.ai (email sending) ────────────────
# Get key: https://app.instantly.ai/  →  Settings  →  Integrations
INSTANTLY_API_KEY=REPLACE_ME
INSTANTLY_BASE_URL=https://api.instantly.ai/api/v2

# The Instantly campaign that approved drafts get pushed into.
# Create the campaign in Instantly first, then copy its UUID here.
INSTANTLY_CAMPAIGN_ID=00000000-0000-0000-0000-000000000000


# ── Sender / approver defaults (shown in UI + logs) ──
DEFAULT_APPROVER_NAME=Maryam
DEFAULT_SENDER_NAME=Maryam
DEFAULT_SENDER_EMAIL=maryam@denalihealth.com


# ── Business rules (tweak without code changes) ──
# Contacts scoring below this are auto-filtered (out of 100)
MIN_CONTACT_SCORE=60

# Hard cap on approved emails sent per day (safety net)
DAILY_SEND_LIMIT=50

# Follow-up sequence — days after first send.
# Matches the prototype: Day 5 / Day 11 / Day 20
FOLLOWUP_DAYS=5,11,20


# ── Gmail mailboxes (production override) ──────
# In dev we read from mailboxes.json on disk.
# In production (Render), paste the SAME JSON array here as a single line:
# MAILBOXES_JSON=[{"email":"...","display_name":"...","smtp_host":"smtp.gmail.com","smtp_port":587,"app_password":"abcd efgh ijkl mnop"}]
MAILBOXES_JSON=


# ── Live category leads (Google Drive + Sheets) ──
# Drive folder that holds one subfolder per category (Alzheimer, Schizophrenia…),
# each containing a Google Sheet with "Clinwire" + "Leads" tabs. The dashboard
# reflects these live — nothing is persisted except sent emails.
LEADS_CATEGORY_FOLDER_ID=1rBfcP7CC7UwY__95vdmTu6FwmwQUqHav
SHEETS_TAB_CLINWIRE=Clinwire
SHEETS_TAB_LEADS=Leads


# ── Future / optional ───────────────────────────
# CLINWIRE_API_KEY=                    # Currently using CSV upload only
# SENTRY_DSN=                          # Add when you want error tracking
